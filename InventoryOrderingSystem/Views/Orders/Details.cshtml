@model InventoryOrderingSystem.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<h2>Order Details</h2>

<div class="mb-3"><strong>Order ID:</strong> @Model.OrderId</div>
<div class="mb-3"><strong>Status:</strong> @Model.Status</div>
<div class="mb-3"><strong>Customer:</strong> @Model.Customer?.FullName</div>
<div class="mb-3"><strong>Total Amount:</strong> ₱@Model.TotalAmount.ToString("N2")</div>
<div class="mb-3"><strong>Date Created:</strong> @Model.DateCreated.ToString("yyyy-MM-dd HH:mm")</div>

<h4>Products</h4>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Product</th>
            <th>Unit Price</th>
            <th>Quantity</th>
            <th>Line Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderItems)
        {
            <tr>
                <td>@item.Product?.ProductName</td>
                <td>₱@item.UnitPrice.ToString("N2")</td>
                <td>@item.Quantity</td>
                <td>₱@item.LineTotal.ToString("N2")</td>
            </tr>
        }
    </tbody>
</table>