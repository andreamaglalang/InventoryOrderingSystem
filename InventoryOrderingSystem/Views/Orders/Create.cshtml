@model InventoryOrderingSystem.ViewModels.CreateOrderViewModel

@{
    ViewData["Title"] = "Create Order";
}

<h2>Create Order</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="CustomerId" class="form-label">Customer</label>
        <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select">
            <option value="">-- Select Customer --</option>
        </select>
        <span asp-validation-for="CustomerId" class="text-danger"></span>
    </div>

    <h4>Order Items</h4>

    @for (int i = 0; i < Model.Items.Count; i++)
    {
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Product</label>
                    <select asp-for="Items[i].ProductId" asp-items="Model.Products" class="form-select">
                        <option value="">-- Select Product --</option>
                    </select>
                    <span asp-validation-for="Items[i].ProductId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Quantity</label>
                    <input asp-for="Items[i].Quantity" class="form-control" />
                    <span asp-validation-for="Items[i].Quantity" class="text-danger"></span>
                </div>
            </div>
    }

    <button type="submit" class="btn btn-primary">Submit Order</button>
</form>