@model InventoryOrderingSystem.ViewModels.CreateOrderViewModel

@{
    ViewData["Title"] = "Create Order";
}

<h2>Create Order</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <h4>Order Items</h4>

    <div id="items-container">
        @for (int i = 0; i < Model.Items.Count; i++)
        {
                <div class="row mb-3 item-row">
                    <div class="col-md-5">
                        <label class="form-label">Product</label>
                        <select asp-for="Items[i].ProductId" asp-items="Model.Products" class="form-select">
                            <option value="">-- Select Product --</option>
                        </select>
                    </div>

                    <div class="col-md-5">
                        <label class="form-label">Quantity</label>
                        <input asp-for="Items[i].Quantity" class="form-control" />
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" class="btn btn-danger remove-item">Remove</button>
                    </div>
                </div>
        }
    </div>

    <div class="mb-3">
        <button type="button" id="add-item" class="btn btn-secondary">Add Another Product</button>
    </div>

    <button type="submit" class="btn btn-primary">Submit Order</button>

    <select id="product-template" class="d-none">
        <option value="">-- Select Product --</option>
        @foreach (var product in Model.Products)
        {
                <option value="@product.Value">@product.Text</option>
        }
    </select>
</form>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />

        <script>
            const itemsContainer = document.getElementById('items-container');
            const addItemButton = document.getElementById('add-item');
            const productTemplate = document.getElementById('product-template').innerHTML;

            function getNextIndex() {
                return itemsContainer.querySelectorAll('.item-row').length;
            }

            addItemButton.addEventListener('click', function () {
                const index = getNextIndex();

                const html = `
                    <div class="row mb-3 item-row">
                        <div class="col-md-5">
                            <label class="form-label">Product</label>
                            <select name="Items[${index}].ProductId" class="form-select">
                                ${productTemplate}
                            </select>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label">Quantity</label>
                            <input name="Items[${index}].Quantity" class="form-control" type="number" min="1" />
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-danger remove-item">Remove</button>
                        </div>
                    </div>
                `;

                itemsContainer.insertAdjacentHTML('beforeend', html);
            });

            itemsContainer.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-item')) {
                    const rows = itemsContainer.querySelectorAll('.item-row');
                    if (rows.length > 1) {
                        e.target.closest('.item-row').remove();
                        reindexItems();
                    }
                }
            });

            function reindexItems() {
                const rows = itemsContainer.querySelectorAll('.item-row');

                rows.forEach((row, index) => {
                    const select = row.querySelector('select');
                    const input = row.querySelector('input');

                    select.name = `Items[${index}].ProductId`;
                    input.name = `Items[${index}].Quantity`;
                });
            }
        </script>
}